"""Highlight the pixels that hold a sting payload.

Given a stego PNG produced by `sting --hide`, this reproduces the exact
header and payload slot layout (the header is self-describing: it carries the
per-image seed that keys the payload permutation) and paints those pixels on
a dimmed copy of the image, so the sparse, spread-out embedding footprint
becomes visible.  No passphrase is needed: this reveals *where* data sits, not
*what* it says -- that stays encrypted.

    highlight-payload STEGO.png OUT.png [--radius N] [--dim F] [--no-header]
"""

import os
import sys
import zlib

# Run against the in-tree stinglib package regardless of where we are called.
_ROOT = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
sys.path.insert(0, _ROOT)

import numpy as np
from PIL import Image

from stinglib.carrier import load_carrier
from stinglib.constants import HDR_LEN, MAGIC
from stinglib.keystream import bits_to_bytes
from stinglib.stego import _header_slots, _payload_slots

# Samples per pixel for each carrier mode.
_CHANNELS = {"L": 1, "LA": 2, "RGB": 3, "RGBA": 4}

PAYLOAD_COLOUR = (255, 40, 40)     # red   -- the ciphertext bits
HEADER_COLOUR = (40, 220, 255)     # cyan  -- the 34-byte locator header


def die(message):
    sys.stderr.write("highlight-payload: %s\n" % message)
    raise SystemExit(1)


class Args:
    pass


def parse_args(argv):
    a = Args()
    a.radius = 1
    a.dim = 0.35
    a.lighten = 0.6
    a.show_header = True
    a.by_bit = False
    it = iter(argv)
    positional = []
    for arg in it:
        if arg == "--radius":
            a.radius = int(next(it))
        elif arg == "--dim":
            a.dim = float(next(it))
        elif arg == "--lighten":
            a.lighten = float(next(it))
        elif arg == "--no-header":
            a.show_header = False
        elif arg == "--by-bit":
            a.by_bit = True
        elif arg in ("-h", "--help"):
            sys.stdout.write(__doc__)
            raise SystemExit(0)
        else:
            positional.append(arg)
    if len(positional) != 2:
        die("usage: highlight-payload STEGO.png OUT.png [--by-bit] "
            "[--radius N] [--dim F] [--lighten F] [--no-header]")
    a.src, a.dst = positional
    return a


def carrying_pixels(carrier, slots):
    """Map slot indices to the unique (y, x) pixels they touch."""
    channels = _CHANNELS[carrier.mode]
    width = carrier.size[0]
    flat = carrier.usable[slots]              # flat sample indices
    pix = np.unique(flat // channels)         # one pixel may hold several bits
    return pix // width, pix % width          # (rows, cols)


def stamp(canvas, rows, cols, colour, radius):
    """Paint a (2*radius+1) square block at each (row, col)."""
    h, w = canvas.shape[:2]
    for dy in range(-radius, radius + 1):
        ry = np.clip(rows + dy, 0, h - 1)
        for dx in range(-radius, radius + 1):
            cx = np.clip(cols + dx, 0, w - 1)
            canvas[ry, cx] = colour


def stamp_block(canvas, rows, cols, fill, radius, border):
    """Paint a bordered block so light fills stay visible on any background."""
    if radius >= 1:
        stamp(canvas, rows, cols, border, radius)
        stamp(canvas, rows, cols, fill, radius - 1)
    else:
        stamp(canvas, rows, cols, fill, 0)


def _pixel_coords(carrier, slots):
    """Return (rows, cols) for the pixels the given SLOTS live in."""
    channels = _CHANNELS[carrier.mode]
    width = carrier.size[0]
    flat = carrier.usable[slots]
    return (flat // channels) // width, (flat // channels) % width


def main(argv):
    a = parse_args(argv)

    try:
        raw = open(a.src, "rb").read()
    except OSError as exc:
        die("cannot read %s: %s" % (a.src, exc))

    try:
        carrier = load_carrier(raw, quiet=True)
    except Exception as exc:                  # noqa: BLE001 - report anything
        die("cannot load carrier: %s" % exc)

    # Locate and validate the self-describing header.
    n = carrier.n_usable
    hslots = _header_slots(n)
    header = bits_to_bytes(carrier.read(hslots))
    if header[:4] != MAGIC:
        die("no sting payload found in %s (is it a stego image?)" % a.src)
    if (zlib.crc32(header[:30]) & 0xFFFFFFFF) != int.from_bytes(
            header[30:34], "big"):
        die("header checksum failed: %s is corrupt or tampered" % a.src)

    seed = header[6:22]
    length = int.from_bytes(header[22:30], "big")
    pslots = _payload_slots(n, seed, hslots, length * 8)

    import io
    base = np.asarray(Image.open(io.BytesIO(raw)).convert("RGB"))
    total_px = carrier.size[0] * carrier.size[1]

    if a.by_bit:
        # Lighten the image, then paint each carrying sample by the bit it
        # stores: 0 -> white, 1 -> black, with a neutral border so the white
        # marks stay visible on the pale backdrop.  "Every pixel that carries
        # information" means the header locator plus the payload.
        canvas = (base.astype(np.float32) * (1.0 - a.lighten)
                  + 255.0 * a.lighten).astype(np.uint8)
        slots = np.concatenate([hslots, pslots]) if a.show_header else pslots
        bits = carrier.read(slots)
        rows, cols = _pixel_coords(carrier, slots)
        one = bits == 1
        zero = ~one
        border = (110, 110, 110)
        stamp_block(canvas, rows[one], cols[one], (0, 0, 0), a.radius, border)
        stamp_block(canvas, rows[zero], cols[zero], (255, 255, 255),
                    a.radius, border)
        Image.fromarray(canvas, "RGB").save(a.dst, format="PNG")
        sys.stdout.write(
            "stego:    %s  (%dx%d %s)\n"
            "carrying: %d bits over %d samples (header %s)\n"
            "  bit=0:  %d  (white)\n"
            "  bit=1:  %d  (black)\n"
            "written:  %s  (on a %.0f%%-lightened image)\n"
            % (a.src, carrier.size[0], carrier.size[1], carrier.mode,
               slots.size, slots.size,
               "included" if a.show_header else "excluded",
               int(zero.sum()), int(one.sum()), a.dst, a.lighten * 100))
        return 0

    # Default mode: dim the image and colour by role.
    canvas = (base.astype(np.float32) * a.dim).astype(np.uint8)
    p_rows, p_cols = carrying_pixels(carrier, pslots)
    if a.show_header:
        h_rows, h_cols = carrying_pixels(carrier, hslots)
        stamp(canvas, h_rows, h_cols, HEADER_COLOUR, a.radius)
    stamp(canvas, p_rows, p_cols, PAYLOAD_COLOUR, a.radius)
    Image.fromarray(canvas, "RGB").save(a.dst, format="PNG")
    sys.stdout.write(
        "stego:    %s  (%dx%d %s)\n"
        "payload:  %d ciphertext bytes -> %d payload pixels\n"
        "header:   %d locator bytes\n"
        "footprint:%.3f%% of pixels carry payload\n"
        "written:  %s  (red = payload%s, on a %.0f%%-dimmed image)\n"
        % (a.src, carrier.size[0], carrier.size[1], carrier.mode,
           length, p_rows.size, HDR_LEN,
           100.0 * p_rows.size / total_px, a.dst,
           ", cyan = header" if a.show_header else "", a.dim * 100))
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
